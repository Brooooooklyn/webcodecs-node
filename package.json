{
  "name": "@napi-rs/webcodecs",
  "version": "1.3.1",
  "description": "WebCodecs API implementation for Node.js using FFmpeg",
  "keywords": [
    "N-API",
    "NAPI",
    "Rust",
    "napi-rs",
    "node-addon",
    "node-addon-api"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Brooooooklyn/webcodecs-node.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Brooooooklyn"
  },
  "license": "MIT",
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./polyfill": {
      "types": "./polyfill.d.ts",
      "import": "./polyfill.js",
      "require": "./polyfill.js"
    }
  },
  "browser": "browser.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js",
    "polyfill.d.ts",
    "polyfill.js",
    "standard.d.ts"
  ],
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/compare.ts",
    "build": "oxnode ./build.ts --platform --release",
    "build:debug": "oxnode ./build.ts --platform",
    "format": "run-p format:rs format:oxfmt",
    "format:oxfmt": "oxfmt",
    "format:rs": "cargo fmt",
    "lint": "oxlint --type-aware",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "demo": "cd example && vite",
    "typecheck": "tsc -b tsconfig.json && tsc --ignoreConfig ./index.d.ts",
    "preversion": "oxnode ./build.ts --platform && git add .",
    "version": "napi version"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint --fix"
    ]
  },
  "devDependencies": {
    "@emnapi/core": "^1.8.1",
    "@emnapi/runtime": "^1.8.1",
    "@napi-rs/canvas": "^0.1.88",
    "@napi-rs/cli": "^3.5.1",
    "@napi-rs/wasm-runtime": "^1.1.1",
    "@oxc-node/cli": "^0.1.0",
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.1",
    "@types/node": "^25.0.10",
    "ava": "^7.0.0",
    "chalk": "^5.6.2",
    "emnapi": "^1.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mediabunny": "1.41.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.41.0",
    "oxlint-tsgolint": "^0.22.0",
    "prettier": "^3.8.1",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.0",
    "webcodecs-polyfill": "^1.0.1",
    "vite-plugin-mkcert": "^2.0.0"
  },
  "peerDependencies": {
    "@napi-rs/canvas": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@napi-rs/canvas": {
      "optional": true
    }
  },
  "napi": {
    "binaryName": "webcodecs",
    "constEnum": false,
    "dtsHeaderFile": "dts-header.d.ts",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "armv7-unknown-linux-gnueabihf"
    ]
  },
  "packageManager": "pnpm@10.33.2",
  "ava": {
    "environmentVariables": {
      "TS_NODE_PROJECT": "./tsconfig.json"
    },
    "extensions": {
      "ts": "module"
    },
    "files": [
      "__test__/**/*.spec.ts"
    ],
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ],
    "timeout": "5m",
    "workerThreads": false
  },
  "engines": {
    "node": ">= 10"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-av",
      "@seydx/node-av-darwin-arm64",
      "@seydx/node-av-darwin-x64",
      "@seydx/node-av-linux-arm64",
      "@seydx/node-av-linux-x64",
      "@seydx/node-av-win32-arm64-mingw",
      "@seydx/node-av-win32-arm64-msvc",
      "@seydx/node-av-win32-x64-mingw",
      "@seydx/node-av-win32-x64-msvc"
    ]
  }
}
